---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="lilQR - Free QR Code Generator | lilAgents"
  description="Create custom QR codes for URLs, vCards, WiFi, and more, with UTM tracking and downloadable PNG or SVG. A free tool by lilAgents."
>
  <section class="pt-12 pb-16 lg:pt-16 bg-white dark:bg-dark">
    <div class="container">
      <div id="qr-tool" class="mx-auto max-w-4xl">

        <header class="text-center mb-8">
          <h1 class="text-3xl sm:text-4xl font-bold text-dark dark:text-white mb-2">
            <span class="text-primary">lil</span>QR
          </h1>
          <p class="text-body-color dark:text-dark-6">Free QR code generator with advanced customization</p>
        </header>

        <div class="bg-white dark:bg-dark-2 rounded-2xl border border-gray-200 dark:border-dark-3 shadow-sm p-6 mb-8">
          <div class="mb-6">
            <div class="flex flex-wrap gap-2 mb-4" id="tab-container"></div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_300px] gap-8 items-start">
            <div>
              <form id="qr-form" class="space-y-4" onsubmit="return false;"></form>

              <div id="utm-section" class="mt-6 p-4 bg-gray-1 dark:bg-dark-2 dark:border dark:border-dark-3 rounded-lg hidden">
                <h3 class="text-lg font-semibold mb-3 text-dark dark:text-white">UTM Parameters</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">UTM Source</label>
                    <input type="text" id="utm-source" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="e.g., google, newsletter">
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">UTM Medium</label>
                    <input type="text" id="utm-medium" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="e.g., cpc, email">
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">UTM Campaign</label>
                    <input type="text" id="utm-campaign" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="e.g., summer_sale">
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">UTM Term</label>
                    <input type="text" id="utm-term" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="e.g., keywords">
                  </div>
                  <div class="sm:col-span-2">
                    <label class="block text-sm font-medium text-gray-700 mb-1">UTM Content</label>
                    <input type="text" id="utm-content" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="e.g., logolink, textlink">
                  </div>
                </div>
              </div>

              <div class="mt-6 p-4 bg-gray-1 dark:bg-dark-2 dark:border dark:border-dark-3 rounded-lg">
                <h3 class="text-lg font-semibold mb-3 text-dark dark:text-white">Customization</h3>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-4">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Foreground Color</label>
                    <input type="color" id="fg-color" value="#000000" class="color-input">
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Background Color</label>
                    <input type="color" id="bg-color" value="#FFFFFF" class="color-input">
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Margin</label>
                    <select id="margin" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                      <option value="1">Small</option>
                      <option value="2">Medium</option>
                      <option value="3" selected>Large</option>
                      <option value="4">Extra Large</option>
                    </select>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Format</label>
                    <select id="export-format" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                      <option value="png" selected>PNG</option>
                      <option value="svg">SVG</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Size (pixels)</label>
                    <select id="export-size" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                      <option value="100">100x100</option>
                      <option value="200">200x200</option>
                      <option value="300">300x300</option>
                      <option value="500" selected>500x500</option>
                      <option value="1000">1000x1000</option>
                    </select>
                  </div>
                </div>
              </div>

            </div>

            <div class="lg:sticky lg:top-6">
              <h3 class="text-lg font-semibold text-dark dark:text-white mb-3">Preview</h3>
              <div class="flex items-center justify-center bg-gray-1 dark:bg-dark rounded-lg p-6 aspect-square">
                <div id="qr-preview" class="text-center">
                  <div class="text-gray-500">
                    <svg class="mx-auto h-16 w-16 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/>
                    </svg>
                    <p>QR code will appear here</p>
                  </div>
                </div>
              </div>

              <div class="mt-4 space-y-3">
                <button type="button" id="generate-btn" class="w-full px-6 py-3 bg-primary text-white rounded-lg font-medium hover:bg-blue-dark transition-colors duration-200">
                  Generate QR Code
                </button>
                <button type="button" id="download-btn" class="w-full px-6 py-3 bg-primary text-white rounded-lg font-medium hover:bg-blue-dark transition-colors duration-200 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                  Download QR Code
                </button>
                <button type="button" id="reset-btn" class="w-full px-6 py-3 bg-gray-1 dark:bg-dark text-dark dark:text-white border border-gray-200 dark:border-dark-3 rounded-lg font-medium hover:bg-gray-200 dark:hover:bg-dark-3 transition-colors duration-200">
                  Reset All
                </button>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <style is:global>
    #qr-tool .tab-active { background-color: var(--color-primary); color: #fff; }
    #qr-tool .tab-inactive { background-color: #f3f4f6; color: #6b7280; }
    #qr-tool .tab-inactive:hover { background-color: #e5e7eb; }
    #qr-tool .color-input { width: 60px; height: 40px; border: 2px solid #e5e7eb; border-radius: 6px; cursor: pointer; background: transparent; }
    #qr-tool #qr-preview canvas { max-width: 100%; height: auto; }
    #qr-tool .bg-blue-600 { background-color: var(--color-primary); }
    #qr-tool .hover\:bg-blue-700:hover { background-color: var(--color-primary-dark); }
    #qr-tool .text-blue-600 { color: var(--color-primary); }
    #qr-tool .focus\:ring-blue-500:focus { --tw-ring-color: var(--color-primary); }
    #qr-tool .focus\:border-blue-500:focus { border-color: var(--color-primary); }
    .dark #qr-tool .tab-inactive { background-color: var(--color-dark); color: #9ca3af; }
    .dark #qr-tool .tab-inactive:hover { background-color: #373737; }
    .dark #qr-tool input,
    .dark #qr-tool select,
    .dark #qr-tool textarea { background-color: var(--color-dark); border-color: #374151; color: #fff; }
    .dark #qr-tool .border-gray-300 { border-color: #374151; }
    .dark #qr-tool .color-input { border-color: #374151; }
    .dark #qr-tool .text-gray-700 { color: #d1d5db; }
    .dark #qr-tool .text-gray-500 { color: #9ca3af; }
  </style>

  <script src="/tools/qr/qrcode.min.js" is:inline></script>
  <script src="/tools/qr/app.js" is:inline></script>
</Layout>
